# ============================================================
# DidiGov — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── AWS Core ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1

# ── AWS Bedrock ─────────────────────────────────────────────
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_KNOWLEDGE_BASE_ID=your_knowledge_base_id_here
BEDROCK_KB_RETRIEVAL_RESULTS=5

# ── AWS DynamoDB ─────────────────────────────────────────────
DYNAMODB_USERS_TABLE=didi_users
DYNAMODB_CONVERSATIONS_TABLE=didi_conversations
DYNAMODB_APPLICATIONS_TABLE=didi_applications

# ── AWS Polly ────────────────────────────────────────────────
POLLY_DEFAULT_VOICE=Aditi
POLLY_DEFAULT_ENGINE=neural
POLLY_DEFAULT_LANGUAGE=hi-IN

# ── AWS S3 ───────────────────────────────────────────────────
# REQUIRED: Backend reads scheme JSON files directly from S3 for form
# field generation (required_user_fields). This is separate from the
# Bedrock Knowledge Base which handles Q&A retrieval. Both are needed.
S3_SCHEMES_BUCKET=your_schemes_bucket_name_here
S3_SCHEMES_PREFIX=schemes/

# ── Deepgram (Speech-to-Text) ──────────────────────────────
# Ultra-fast transcription for Indian regional languages
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Sarvam AI (Indic Speech-to-Text) ─────────────────────────
# Highly accurate transcription for 10 Indian regional languages
SARVAM_API_KEY=your_sarvam_api_key_here

# ── Groq (Speech-to-Text) — Multi-key Fallback ──────────────
# Add multiple API keys separated by commas.
# The backend rotates through them to avoid rate-limit failures.
# Example: GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_API_KEYS=your_groq_api_key_here
GROQ_WHISPER_MODEL=whisper-large-v3

# ── Security / JWT ───────────────────────────────────────────
# Used for session tokens, user identification, and API security.
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── FastAPI ──────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# ── Session ──────────────────────────────────────────────────
SESSION_TTL_HOURS=24
MAX_CONVERSATION_HISTORY=20
